# -----------------------------
# Go library (cgo)
# -----------------------------

go_library(
    name = "prover",
    srcs = [
        "rapidsnark.go",
        "select_rapidsnark.h",
        "rapidsnark_vendor/prover.h",
        "build_darwin_amd64.go",
        "build_darwin_arm64.go",
        "build_linux_amd64.go",
        "build_linux_arm64.go",
    ],
    cgo = True,
    copts = [
        "-I.",
        "-Irapidsnark_vendor",
    ],
    clinkopts = [
        "-fopenmp",
        "-D_GLIBCXX_USE_CXX11_ABI=1",  # ensure ABI compatibility with vendored .a
    ],
    cdeps = [
        ":librapidsnark_linux_amd64",
        ":libgmp_linux_amd64",
        # ":stdcpp_linux",
    ],
    importpath = "github.com/iden3/go-rapidsnark/prover",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_iden3_go_rapidsnark_types//:types",
    ],
)

alias(
    name = "go_default_library",
    actual = ":prover",
    visibility = ["//visibility:public"],
)
