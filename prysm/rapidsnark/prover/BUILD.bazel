load("@io_bazel_rules_go//go:def.bzl", "go_library")

# -----------------------------
# C++ vendored static libraries
# -----------------------------

cc_import(
    name = "rapidsnark_static",
    static_library = "rapidsnark_vendor/librapidsnark-fr-fq.a",
    hdrs = glob(["include/**/*.h"]),
    visibility = ["//visibility:public"],
)

cc_library(
    name = "librapidsnark_linux_amd64",
    deps = [":rapidsnark_static"],
    linkopts = [
        "-lstdc++",   # if you built against libstdc++
        # or "-lc++" if you rebuilt against libc++
        # "-lgmp",      # needed per CMakeLists.txt
        "-lm",
    ],
    visibility = ["//visibility:public"],
)

